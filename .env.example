# LLM config (Berget.AI or any OpenAI-compatible service)
BERGET_API_KEY=your_api_key_here
BERGET_BASE_URL=https://api.berget.ai/v1
BERGET_MODEL=openai/gpt-oss-120b

# Generic OpenAI-compatible aliases are also supported:
# OPENAI_API_KEY=your_api_key_here
# OPENAI_BASE_URL=https://api.example.com/v1
# OPENAI_MODEL=your_model_here

# Optional: Tavily network search if DuckDuckGo is replaced later.
# TAVILY_API_KEY=your_tavily_key_here
